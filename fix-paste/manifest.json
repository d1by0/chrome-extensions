{
  "manifest_version": 3,
  "name": "Fix Paste",
  "version": "1.1.0",
  "description": "Extract clean, structured markdown, plain text, or JSON content from any webpage, removing ads, navigation menus, and footers.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "contextMenus",
    "storage",
    "alarms",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "assets/fix_paste.avif"
  },
  "icons": {
    "16": "assets/fix_paste.avif",
    "48": "assets/fix_paste.avif",
    "128": "assets/fix_paste.avif"
  },
  "commands": {
    "quick-extract": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "Quick copy clean content of the current tab"
    }
  }
}
